#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROGRAM_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
VENV_DIR="$PROGRAM_DIR/.venv"
PLIST_NAME="com.kittentts.wyoming.plist"
PLIST_SRC="$SCRIPT_DIR/$PLIST_NAME"
PLIST_DST="$HOME/Library/LaunchAgents/$PLIST_NAME"
LOG_DIR="$HOME/Library/Logs/kittentts"
CONFIG_DIR="$HOME/.config/kittentts"
CONFIG_FILE="$CONFIG_DIR/config"

echo "Installing wyoming-kittentts service..."

# Run setup if venv doesn't exist
if [ ! -d "$VENV_DIR" ]; then
    echo "==> Running setup..."
    "$SCRIPT_DIR/setup"
fi

if [ ! -x "$VENV_DIR/bin/python" ]; then
    echo "Error: venv not found at $VENV_DIR. Run script/setup first."
    exit 1
fi

# Create config file with defaults (won't overwrite existing)
mkdir -p "$CONFIG_DIR"
if [ ! -f "$CONFIG_FILE" ]; then
    cat > "$CONFIG_FILE" <<'EOF'
MODEL="KittenML/kitten-tts-mini-0.8"
VOICE="Jasper"
URI="tcp://0.0.0.0:10200"
# DEBUG=true
EOF
    echo "==> Created config: $CONFIG_FILE"
else
    echo "==> Using existing config: $CONFIG_FILE"
fi

# Create directories
mkdir -p "$LOG_DIR"
mkdir -p "$HOME/Library/LaunchAgents"

# Generate plist from template
sed -e "s|<SCRIPT-DIR>|$SCRIPT_DIR|g" \
    -e "s|<LOG-DIR>|$LOG_DIR|g" \
    "$PLIST_SRC" > "$PLIST_DST"

# Unload if already loaded
launchctl bootout gui/$UID "$PLIST_DST" 2>/dev/null || true

# Load the service
if ! launchctl bootstrap gui/$UID "$PLIST_DST"; then
    echo "Error: Failed to load service."
    echo "Try running: launchctl bootstrap gui/$UID $PLIST_DST"
    exit 1
fi

echo ""
echo "Service installed and started."
echo "  Config: $CONFIG_FILE"
echo "  Plist:  $PLIST_DST"
echo "  Logs:   $LOG_DIR/"
echo ""
echo "Commands:"
echo "  Edit config:  \$EDITOR $CONFIG_FILE"
echo "  Restart:      launchctl kickstart -k gui/$UID/com.kittentts.wyoming"
echo "  Uninstall:    script/uninstall"
