#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROGRAM_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PLIST_NAME="com.local.wyoming-kittentts.plist"
PLIST_DST="$HOME/Library/LaunchAgents/$PLIST_NAME"
LOG_DIR="$HOME/Library/Logs/kittentts"
CONFIG_DIR="$HOME/.config/kittentts"
CONFIG_FILE="$CONFIG_DIR/config.json"

echo "Installing wyoming-kittentts service..."

if ! command -v uv &>/dev/null; then
    echo "Error: uv is not installed. Install it: https://docs.astral.sh/uv/getting-started/installation/"
    exit 1
fi

# Sync dependencies
echo "==> Syncing dependencies..."
(cd "$PROGRAM_DIR" && uv sync)

# Install as a uv tool (provides wyoming-kittentts in ~/.local/bin)
echo "==> Installing wyoming-kittentts tool..."
uv tool install --from "$PROGRAM_DIR" wyoming-kittentts --force

# Locate the installed tool
TOOL="$(uv tool dir --bin)/wyoming-kittentts"
if [ ! -x "$TOOL" ]; then
    echo "Error: wyoming-kittentts not found at $TOOL"
    exit 1
fi
echo "==> Installed tool: $TOOL"

# Create config file with defaults (won't overwrite existing)
mkdir -p "$CONFIG_DIR"
if [ ! -f "$CONFIG_FILE" ]; then
    cat > "$CONFIG_FILE" <<'EOF'
{
  "model": "KittenML/kitten-tts-mini-0.8",
  "voice": "Jasper",
  "uri": "tcp://0.0.0.0:10200",
  "debug": false
}
EOF
    echo "==> Created config: $CONFIG_FILE"
else
    echo "==> Using existing config: $CONFIG_FILE"
fi

# Create directories
mkdir -p "$LOG_DIR"
mkdir -p "$HOME/Library/LaunchAgents"

# Generate plist
cat > "$PLIST_DST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.local.wyoming-kittentts</string>
    <key>ProgramArguments</key>
    <array>
        <string>$TOOL</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>$LOG_DIR/stdout.log</string>
    <key>StandardErrorPath</key>
    <string>$LOG_DIR/stderr.log</string>
</dict>
</plist>
EOF

# Unload if already loaded
launchctl bootout gui/$UID "$PLIST_DST" 2>/dev/null || true

# Load the service
if ! launchctl bootstrap gui/$UID "$PLIST_DST"; then
    echo "Error: Failed to load service."
    echo "Try running: launchctl bootstrap gui/$UID $PLIST_DST"
    exit 1
fi

echo ""
echo "Service installed and started."
echo "  Config: $CONFIG_FILE"
echo "  Plist:  $PLIST_DST"
echo "  Logs:   $LOG_DIR/"
echo ""
echo "Commands:"
echo "  Edit config:  \$EDITOR $CONFIG_FILE"
echo "  Restart:      launchctl kickstart -k gui/$UID/com.local.wyoming-kittentts"
echo "  Uninstall:    script/uninstall"
