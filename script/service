#!/bin/bash
set -e

CONFIG_FILE="$HOME/.config/kittentts/config"
SHIM="$1"

if [ -z "$SHIM" ] || [ ! -x "$SHIM" ]; then
    echo "Error: wyoming-kittentts shim not found. Run script/install first."
    exit 1
fi

# Defaults
MODEL="KittenML/kitten-tts-mini-0.8"
VOICE="Jasper"
URI="tcp://0.0.0.0:10200"
DEBUG=""

# Source config if it exists
if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
fi

FLAGS="--uri $URI --model $MODEL --voice $VOICE"
if [ "$DEBUG" = "true" ]; then
    FLAGS="$FLAGS --debug"
fi

exec "$SHIM" $FLAGS
