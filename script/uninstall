#!/bin/bash
set -e

PLIST_NAME="com.local.wyoming-kittentts.plist"
PLIST_DST="$HOME/Library/LaunchAgents/$PLIST_NAME"

echo "Uninstalling wyoming-kittentts service..."

if [ -f "$PLIST_DST" ]; then
    launchctl bootout gui/$UID "$PLIST_DST" 2>/dev/null || true
    rm "$PLIST_DST"
    echo "Service uninstalled."
else
    echo "Service not installed."
fi

# Remove the uv tool
if command -v uv &>/dev/null; then
    uv tool uninstall wyoming-kittentts 2>/dev/null && echo "Tool uninstalled." || true
fi
